# Database (Neon locally: docker-compose postgres)
DATABASE_URL="postgresql://diaspora:diaspora@localhost:5433/diaspora"

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3001"

# Stripe (optional for v1 dev — mock payment mode if unset)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# File storage: local uploads folder in dev; R2 in production
STORAGE_MODE="local"
UPLOAD_DIR="./uploads"
# R2 (production)
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME=""
# R2_PUBLIC_URL=""

# Seed admin (first run only)
SEED_ADMIN_EMAIL="admin@sozo.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# Dev: allow mock payments without Stripe
MOCK_PAYMENTS="true"
